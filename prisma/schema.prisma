// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Visitor {
  id        Int      @id @default(autoincrement())
  ip        String?
  userAgent String?
  path      String
  createdAt DateTime @default(now())
}
